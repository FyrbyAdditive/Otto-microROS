// WiFi and micro-ROS Agent Configuration
// =========================================
// Copy this file to wifi_credentials.h and fill in your values.
// wifi_credentials.h is .gitignored and will not be committed.

#ifndef WIFI_CREDENTIALS_H
#define WIFI_CREDENTIALS_H

#define WIFI_SSID      "YOUR_WIFI_SSID"
#define WIFI_PASSWORD  "YOUR_WIFI_PASSWORD"

// IP address of the machine running the micro-ROS agent
#define AGENT_IP       "192.168.1.100"
#define AGENT_PORT     8888

// Optional: static IP for the ESP32 (uncomment to use instead of DHCP)
// #define STATIC_IP      "192.168.1.200"
// #define STATIC_GATEWAY "192.168.1.1"
// #define STATIC_SUBNET  "255.255.255.0"

#endif // WIFI_CREDENTIALS_H
