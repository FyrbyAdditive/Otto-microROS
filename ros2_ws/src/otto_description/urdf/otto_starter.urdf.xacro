<?xml version="1.0"?>
<!--
  Otto Starter Kit — URDF (xacro)
  Coordinate system: ROS REP-103 (X=forward, Y=left, Z=up)
  base_footprint : ground plane (Z = 0)
  base_link      : wheel axle height (Z = wheel_radius above ground)

  Mesh joint origins are printed by scripts/export_meshes.py — update here
  if the STEP file is re-exported.

  All body_* STL meshes share the same body_link joint origin (body_shell
  centroid) so all visual origins within body_link are (0 0 0).

  Each wheel link has two visuals: rim (dark grey) and tire (black rubber).
  The tire and rim STLs share the same axle-midpoint reference origin.
-->
<robot name="otto_starter" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Parameters                                                        -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <xacro:property name="wheel_radius"   value="0.0245"/>   <!-- m -->
  <xacro:property name="wheel_base"     value="0.0833"/>   <!-- m  (track width) -->
  <xacro:property name="wheel_width"    value="0.008"/>    <!-- m -->
  <xacro:property name="wheel_mass"     value="0.020"/>    <!-- kg -->
  <xacro:property name="body_mass"      value="0.300"/>    <!-- kg -->
  <xacro:property name="caster_mass"    value="0.010"/>    <!-- kg -->

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Materials                                                         -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <material name="otto_white">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>
  <material name="otto_blue">
    <color rgba="0.12 0.47 0.71 1.0"/>
  </material>
  <material name="otto_dark">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>
  <material name="otto_dark_grey">
    <color rgba="0.25 0.25 0.25 1.0"/>
  </material>
  <material name="otto_black">
    <color rgba="0.05 0.05 0.05 1.0"/>
  </material>
  <material name="rubber_black">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <material name="led_white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="sensor_green">
    <color rgba="0.0 0.8 0.2 0.8"/>
  </material>
  <material name="pcb_green">
    <color rgba="0.05 0.35 0.05 1.0"/>
  </material>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Helper macros                                                     -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(y*y+z*z)/12}" ixy="0" ixz="0"
               iyy="${m*(x*x+z*z)/12}" iyz="0"
               izz="${m*(x*x+y*y)/12}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0"
               iyy="${m*(3*r*r+h*h)/12}" iyz="0"
               izz="${m*r*r/2}"/>
    </inertial>
  </xacro:macro>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  base_footprint — ground reference frame (Z = 0)                  -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  base_link — wheel axle height                                     -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="base_link">
    <xacro:box_inertia m="${body_mass}" x="0.072" y="0.072" z="0.072"/>
  </link>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Body shell — multiple visuals for different colours               -->
  <!--                                                                    -->
  <!--  body_link joint xyz = body_shell centroid (from export script)    -->
  <!--    body_shell:  joint xyz="0.0230 0.0000 0.0242"                  -->
  <!--                                                                    -->
  <!--  All sub-meshes share the same reference origin as body_shell so  -->
  <!--  all visual origins are (0 0 0).                                   -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="body_link">
    <!-- Middle: main cylindrical shell — dark grey -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/body_shell.stl"/>
      </geometry>
      <material name="otto_dark_grey"/>
    </visual>
    <!-- Middle: rear battery clips — dark grey -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/body_clips.stl"/>
      </geometry>
      <material name="otto_dark_grey"/>
    </visual>
    <!-- Top: dome and cap sections — white -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/body_top.stl"/>
      </geometry>
      <material name="otto_white"/>
    </visual>
    <!-- Top: logo line engravings — black -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/body_top_lines.stl"/>
      </geometry>
      <material name="otto_black"/>
    </visual>
    <!-- Unnamed COMPOUND: bottom shell — black -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/body_bottom.stl"/>
      </geometry>
      <material name="otto_black"/>
    </visual>
    <!-- Unnamed COMPOUND: front face panel — dark grey -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/body_face.stl"/>
      </geometry>
      <material name="otto_dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.072 0.072 0.072"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${body_mass}" x="0.072" y="0.072" z="0.072"/>
  </link>

  <joint name="body_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="body_link"/>
    <origin xyz="0.0230 0.0000 0.0242" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Wheels — two visuals per wheel (rim: dark grey, tyre: black)     -->
  <!--                                                                    -->
  <!--  Meshes centred at axle midpoint — rotate around Y correctly.     -->
  <!--  joint xyz from export_meshes.py (det=+1 transform):              -->
  <!--    wheel_left:  joint xyz="0.0000  0.0416 0.0000"                -->
  <!--    wheel_right: joint xyz="0.0000 -0.0416 0.0000"                -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="left_wheel_link">
    <!-- Hub + outer rim — dark grey -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/wheel_left_rim.stl"/>
      </geometry>
      <material name="otto_dark_grey"/>
    </visual>
    <!-- Rubber tyre — near-black -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/wheel_left_tire.stl"/>
      </geometry>
      <material name="rubber_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel_link"/>
    <origin xyz="-0.0000 0.0416 0.0000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel_link">
    <!-- Hub + outer rim — dark grey -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/wheel_right_rim.stl"/>
      </geometry>
      <material name="otto_dark_grey"/>
    </visual>
    <!-- Rubber tyre — near-black -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/wheel_right_tire.stl"/>
      </geometry>
      <material name="rubber_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel_link"/>
    <origin xyz="-0.0000 -0.0416 0.0000" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Caster (front ball caster)                                        -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="caster_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/caster.stl"/>
      </geometry>
      <material name="otto_dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.006"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${caster_mass}" x="0.012" y="0.012" z="0.012"/>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="caster_link"/>
    <origin xyz="0.0430 0.0000 -0.0190" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  LED Ring                                                          -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="led_ring_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/led_ring.stl"/>
      </geometry>
      <material name="pcb_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.002"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.005" x="0.05" y="0.05" z="0.002"/>
  </link>

  <joint name="led_ring_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="led_ring_link"/>
    <origin xyz="0.0231 -0.0001 0.0516" rpy="0 0 0"/>
  </joint>

  <!-- ── Individual LED frames (positions relative to base_link) ──────
       Values from export_meshes.py LED ring frame positions output.
       These are used by otto_visualizer to publish marker poses.       -->

  <xacro:macro name="led_frame" params="n x y z">
    <link name="led_${n}_link"/>
    <joint name="led_${n}_joint" type="fixed">
      <parent link="base_link"/>
      <child  link="led_${n}_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- 13 LED pads extracted from 'LED Ring' CAF group, sorted by angle -->
  <xacro:led_frame n="0"  x="0.0049" y="-0.0104" z="0.0532"/>
  <xacro:led_frame n="1"  x="0.0126" y="-0.0181" z="0.0532"/>
  <xacro:led_frame n="2"  x="0.0231" y="-0.0209" z="0.0532"/>
  <xacro:led_frame n="3"  x="0.0336" y="-0.0181" z="0.0532"/>
  <xacro:led_frame n="4"  x="0.0412" y="-0.0104" z="0.0532"/>
  <xacro:led_frame n="5"  x="0.0441" y=" 0.0001" z="0.0532"/>
  <xacro:led_frame n="6"  x="0.0231" y=" 0.0001" z="0.0532"/>
  <xacro:led_frame n="7"  x="0.0021" y=" 0.0001" z="0.0532"/>
  <xacro:led_frame n="8"  x="0.0412" y=" 0.0106" z="0.0532"/>
  <xacro:led_frame n="9"  x="0.0336" y=" 0.0183" z="0.0532"/>
  <xacro:led_frame n="10" x="0.0231" y=" 0.0211" z="0.0532"/>
  <xacro:led_frame n="11" x="0.0126" y=" 0.0183" z="0.0532"/>
  <xacro:led_frame n="12" x="0.0049" y=" 0.0106" z="0.0532"/>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Ultrasonic sensor                                                 -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="ultrasonic_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/ultrasonic.stl"/>
      </geometry>
      <material name="sensor_green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.010 0.005 0.006"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.002" x="0.010" y="0.005" z="0.006"/>
  </link>

  <joint name="ultrasonic_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="ultrasonic_link"/>
    <origin xyz="0.0520 0.0000 0.0260" rpy="0 0 0"/>
  </joint>

  <!-- Sensor ray origin — midpoint between transducers, pointing forward -->
  <link name="ultrasonic_sensor_frame"/>
  <joint name="ultrasonic_sensor_joint" type="fixed">
    <parent link="ultrasonic_link"/>
    <child  link="ultrasonic_sensor_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  Line sensors                                                      -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="line_sensor_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/line_sensor_left.stl"/>
      </geometry>
      <material name="pcb_green"/>
    </visual>
    <xacro:box_inertia m="0.003" x="0.014" y="0.034" z="0.002"/>
  </link>

  <joint name="line_sensor_left_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="line_sensor_left_link"/>
    <origin xyz="0.0347 0.0130 -0.0064" rpy="0 0 0"/>
  </joint>

  <link name="line_sensor_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://otto_description/meshes/line_sensor_right.stl"/>
      </geometry>
      <material name="pcb_green"/>
    </visual>
    <xacro:box_inertia m="0.003" x="0.014" y="0.034" z="0.002"/>
  </link>

  <joint name="line_sensor_right_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="line_sensor_right_link"/>
    <origin xyz="0.0347 -0.0130 -0.0064" rpy="0 0 0"/>
  </joint>

  <!-- ══════════════════════════════════════════════════════════════════ -->
  <!--  IMU (no mesh, just a TF frame at approximate board location)      -->
  <!-- ══════════════════════════════════════════════════════════════════ -->
  <link name="imu_link"/>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0.023 0.000 0.010" rpy="0 0 0"/>
  </joint>

</robot>
